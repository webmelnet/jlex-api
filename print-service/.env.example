# Print Service Configuration

# Server Port
PORT=3001

# Printer USB IDs (find these using 'lsusb' on Linux or Device Manager on Windows)
# Default values for Gprinter GP-1324D
PRINTER_VENDOR_ID=0x28e9
PRINTER_PRODUCT_ID=0x0289

# Environment
NODE_ENV=production

# Store Information (optional - can be sent from backend)
STORE_NAME="Your Store Name"
STORE_ADDRESS="123 Main Street, City"
STORE_PHONE="(123) 456-7890"
STORE_EMAIL="info@yourstore.com"
